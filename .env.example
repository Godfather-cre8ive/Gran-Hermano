# Gran Hermano Academy — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Server
PORT=3000
NODE_ENV=production

# Security — CHANGE THESE IN PRODUCTION
JWT_SECRET=gha_super_secret_change_this_immediately_in_production_2025

# Admin Credentials — CHANGE THESE
ADMIN_USERNAME=admin
ADMIN_PASSWORD=gha@admin2025
# Run: node -e "const b=require('bcryptjs');b.hash('yourpassword',10).then(h=>console.log(h))" to generate hash
ADMIN_PASSWORD_HASH=$2a$10$rBV2JDeWW3.vKyeQcB3iMOqFt0VsZbHTgrwKiPFbNHwV3WlNRMNAC

# Email (optional — for contact form notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@granhermano.sch.ng
SMTP_PASS=your_email_app_password
NOTIFY_EMAIL=info@granhermano.sch.ng
